{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)",
      "uids": {
        ".indexOn": [".value"]
      },
      "emails": {
        ".indexOn": [".value"]
      }
    },

    "profiles": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['displayName'])",
        "displayName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        }
      }
    },

    "appState": {
      // USER-CENTRIC MODEL (May 2026):
      // - transactions_public: shared data (groceries, lent, returned, settlement) — all users read/write
      // - transactions_private: per-user expenses & rent — all users read/write (client filters by userId)
      // - budgets, payers: all users read/write
      // - houses, categories, currency, electricRate: admin-only write (structural data)

      "transactions_public": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["type", "category", "date", "createdAt", "userId"],
        "$txId": {
          ".validate": "newData.hasChildren(['id','type','category','amount','date','createdAt'])",
          "amount": { ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 99999999" },
          "type": { ".validate": "newData.isString() && newData.val().matches(/^(groceries|rent|lent|returned|settlement|expense)$/)" },
          "date": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" }
        }
      },

      "transactions_private": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["type", "category", "date", "createdAt", "userId"],
        "$txId": {
          ".validate": "newData.hasChildren(['id','type','category','amount','date','createdAt'])",
          "amount": { ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 99999999" },
          "type": { ".validate": "newData.isString() && newData.val().matches(/^(expense|groceries|rent|lent|returned|settlement|income)$/)" },
          "date": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" }
        }
      },

      "houses": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)"
      },
      "categories": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)"
      },
      "budgets": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": [".value"]
      },
      "recurringTemplates": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)"
      },
      "payers": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": [".value"]
      },
      "currency": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)"
      },
      "electricRate": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)"
      },

      "transactions": {
        ".read": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)",
        ".write": "auth != null && (root.child('admins/uids').child(auth.uid).val() === true || root.child('admins/emails').child(auth.token.email.replace('.',',')).val() === true)"
      },

      "lastUpdated": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.isNumber() && newData.val() <= now + 60000"
      },

      "lastWriteId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
